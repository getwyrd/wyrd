# /etc/wyrd/s3.env — configuration for wyrd-s3.service.
# Mirrors the M4 blueprint's B.5 invocation (docs/design/architecture/
# m4-first-deployment-blueprint.md). Installed 0640 root:wyrd — it holds the
# gateway credentials; keep it out of world-readable backups.
#
#   --metadata-backend fdb        FoundationDB, the production backend (ADR-0042);
#                                 reads WYRD_FDB_CLUSTER_FILE below.
#   --coordination-backend etcd   discovers the registered D servers.
#   --s3-listen                   HTTP listen address (TLS terminates in front of
#                                 this process — the gateway itself is plain HTTP).
#   --region                      the SigV4 region clients must scope to.
#   --endpoints                   the D-server fleet.
WYRD_S3_ARGS=--metadata-backend fdb --coordination-backend etcd --s3-listen 0.0.0.0:8080 --region zone-a --endpoints http://10.0.1.d0:50051,http://10.0.1.d1:50051

# The FDB cluster file (see custodian.env.example for the rewrite note).
WYRD_FDB_CLUSTER_FILE=/etc/foundationdb/fdb.cluster

# The etcd coordination ensemble (comma-separated client endpoints).
WYRD_ETCD_ENDPOINTS=http://10.0.1.e0:2379,http://10.0.1.e1:2379,http://10.0.1.e2:2379

# Gateway credentials — REQUIRED, auth is fail-closed (no anonymous access).
# Read from the environment so they never appear on a command line.
#
# COMMENTED OUT deliberately: the CLI checks these variables for PRESENCE, so an
# empty-but-set `WYRD_S3_ACCESS_KEY=` would start the gateway with empty-string
# credentials instead of refusing. Uncomment AND fill both, or the role exits
# with "--access-key … is required" — the failure you want.
#WYRD_S3_ACCESS_KEY=
#WYRD_S3_SECRET_KEY=
