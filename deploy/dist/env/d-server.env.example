# /etc/wyrd/d-server.env — per-host configuration for wyrd-d-server.service.
# Mirrors the M4 blueprint's B.4 invocation (docs/design/architecture/
# m4-first-deployment-blueprint.md). Every value below is REQUIRED thought:
#
#   --bind             gRPC listen address (0.0.0.0:50051 to accept peers).
#   --advertise-addr   what peers DIAL — must be this node's routable address.
#   --id               this D server's stable numeric identity (unique per fleet).
#   --failure-domain   MUST be honest — it is what makes RS(k,m) durability real.
#                      Never give two servers on one box different labels.
#   --coordination-backend etcd   registers id·endpoint·fd and renews the lease.
#   --group            the zone/group name gateways discover this server under.
#
# The unit pins --data-dir to /var/lib/wyrd/d-server (STATE_DIRECTORY); add your
# own --data-dir here only to override that (last flag wins).
WYRD_D_SERVER_ARGS=--bind 0.0.0.0:50051 --advertise-addr 10.0.1.N:50051 --id N --failure-domain fdN --coordination-backend etcd --group zone-a

# The etcd coordination ensemble (comma-separated client endpoints).
WYRD_ETCD_ENDPOINTS=http://10.0.1.e0:2379,http://10.0.1.e1:2379,http://10.0.1.e2:2379
